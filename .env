# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=event_locator
DB_USER=postgres
DB_PASSWORD=1234

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars_long
JWT_EXPIRY=7d

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# API Keys (Optional - for Google Maps integration)
GOOGLE_MAPS_API_KEY=your_api_key_here

# i18n Configuration
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,es,fr,de

# Logging
LOG_LEVEL=info
